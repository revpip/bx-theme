{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "midnight", "name": "Midnight", "color": "#0f172a" },
        { "slug": "ink", "name": "Ink", "color": "#111827" },
        { "slug": "gold", "name": "Business Gold", "color": "#d4af37" },
        { "slug": "mist", "name": "Mist", "color": "#e5e7eb" },
        { "slug": "muted", "name": "Muted", "color": "#94a3b8" },
        { "slug": "white", "name": "White", "color": "#ffffff" }
      ]
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1180px"
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
          "slug": "inter",
          "name": "Inter/System"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "Small" },
        { "slug": "base", "size": "1rem", "name": "Base" },
        { "slug": "large", "size": "1.25rem", "name": "Large" },
        { "slug": "x-large", "size": "2rem", "name": "Extra Large" },
        { "slug": "hero", "size": "clamp(3rem, 8vw, 6.8rem)", "name": "Hero" }
      ]
    },
    "spacing": {
      "spacingScale": {
        "steps": 7,
        "mediumStep": 1.5,
        "unit": "rem"
      }
    }
  },
  "styles": {
    "color": {
      "background": "#0f172a",
      "text": "#e5e7eb"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "lineHeight": "1.65"
    },
    "elements": {
      "link": {
        "color": { "text": "#d4af37" }
      },
      "heading": {
        "typography": { "lineHeight": "1.08", "fontWeight": "800" },
        "color": { "text": "#ffffff" }
      }
    }
  }
}
